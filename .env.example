# Database
# Local Postgres via docker-compose: `docker compose up -d`
DATABASE_URL="postgresql://alfred:alfred@localhost:5432/alfred"

# BetterAuth
# Generate random string: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# GitHub OAuth App (used only for "Login with GitHub" on /login and /signup)
# Create at: github.com/settings/developers → OAuth Apps → New
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# GitHub App (used for repo install, PR/webhook access, vectorization — separate from the OAuth app above)
# Create at: github.com/settings/apps → New GitHub App
# Permissions needed: Contents: Read, Pull requests: Read & Write, Metadata: Read, Webhooks: Read & Write
# Callback URL: http://localhost:3000/api/github/callback
# Webhook URL: <your ngrok URL>/api/webhooks/github
GITHUB_APP_ID=""
# Paste the full contents of the downloaded .pem file (keep the BEGIN/END lines, wrap in quotes)
GITHUB_APP_PRIVATE_KEY=""
GITHUB_APP_CLIENT_ID=""
GITHUB_APP_CLIENT_SECRET=""

# Google OAuth
# Create at: console.cloud.google.com → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Upstash Redis (Permission Cache)
# Get from: console.upstash.com → Create Database → REST API
UPSTASH_REDIS_URL=""
UPSTASH_REDIS_TOKEN=""

# Inngest (Async Workflows)
# Local dev: run `npx inngest-cli@latest dev` and set INNGEST_DEV so the SDK
# talks to the local Dev Server instead of requiring a cloud event key.
# Production: get from app.inngest.com → Settings → Event Keys
INNGEST_DEV="1"
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Razorpay (Billing)
# Get from: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
# Create at: dashboard.razorpay.com → Subscriptions → Plans → New Plan (one for Pro, one for Team)
RAZORPAY_PLAN_ID_PRO=""
RAZORPAY_PLAN_ID_TEAM=""

# GitHub Webhook
# Generate random string: openssl rand -base64 32
GITHUB_WEBHOOK_SECRET=""

# OpenAI (chat completions + pgvector embeddings — model swappable via OPENAI_MODEL)
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"

# AI Review (Phase 9)
# Diff line threshold before Alfred switches from sending the full diff to
# embedding + ranking chunks. Use 200 in development, 500 in production.
MAX_DIFF_LINES="200"

# Resend (Daily Digest emails — Phase 12)
# Get from: resend.com → API Keys. Free tier: 3000 emails/month.
# If unset, the daily digest workflow still runs and creates in-app
# notifications, it just skips sending the email.
RESEND_API_KEY=""