# --- Database ---
# PostgreSQL connection string (including pgvector if using vector features locally)
DATABASE_URL="postgresql://user:password@localhost:5432/alfred"

# --- Better Auth ---
# Secret used for session encryption. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-better-auth-secret"
# Base URL of your application
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# --- OAuth Providers ---
# GitHub OAuth App credentials (for user login)
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
# Google OAuth App credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- GitHub App & Webhooks ---
# GitHub App ID and Private Key (for repository operations)
GITHUB_APP_ID="your-github-app-id"
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# Secret for verifying GitHub webhooks
GITHUB_WEBHOOK_SECRET="your-github-webhook-secret"

# --- AI Models ---
# OpenAI API Key for agents and embeddings
OPENAI_API_KEY="sk-..."
# Model to use for AI features (e.g., gpt-4o, gpt-4-turbo)
OPENAI_MODEL="gpt-4o"

# --- Inngest ---
# Keys for Inngest cloud (optional for local development with Inngest Dev Server)
INNGEST_EVENT_KEY="your-inngest-event-key"
INNGEST_SIGNING_KEY="your-inngest-signing-key"

# --- Redis (Upstash) ---
# Used for permission caching (Zanzibar layer)
UPSTASH_REDIS_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_TOKEN="your-redis-token"

# --- Razorpay ---
# Razorpay API credentials for billing
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
# Secret for verifying Razorpay webhooks
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# --- Notifications ---
# Resend API Key for sending emails (daily digest, invites)
RESEND_API_KEY="re_..."

# --- Sentry Error Monitoring ---
# DSN from sentry.io (Settings > Projects > Client Keys)
NEXT_PUBLIC_SENTRY_DSN="https://your-key@o0.ingest.sentry.io/0"
# Auth token for source map uploads in CI (optional)
SENTRY_AUTH_TOKEN=""

# --- Feature Flags & Configuration ---
# Maximum number of lines to include in AI code review diffs
MAX_DIFF_LINES="500"
# Whether to require a merged PR before allowing a feature to be shipped
RELEASE_READINESS_REQUIRE_MERGED="true"
