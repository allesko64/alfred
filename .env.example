# Database
# Local Postgres via docker-compose: `docker compose up -d`
DATABASE_URL="postgresql://alfred:alfred@localhost:5432/alfred"

# BetterAuth
# Generate random string: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# GitHub OAuth App
# Create at: github.com/settings/developers → OAuth Apps → New
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth
# Create at: console.cloud.google.com → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Anthropic (Claude)
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=""

# Upstash Redis (Permission Cache)
# Get from: console.upstash.com → Create Database → REST API
UPSTASH_REDIS_URL=""
UPSTASH_REDIS_TOKEN=""

# Inngest (Async Workflows)
# Get from: app.inngest.com → Settings → Event Keys
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Razorpay (Billing)
# Get from: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# GitHub Webhook
# Generate random string: openssl rand -base64 32
GITHUB_WEBHOOK_SECRET=""

# OpenAI (for pgvector embeddings)
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=""